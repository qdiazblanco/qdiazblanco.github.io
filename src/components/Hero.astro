---
import { SURFACES, analyse } from '../lib/morse';
// Same filter the canvas uses, so chip indices line up with hero.ts.
const surfaces = SURFACES.filter((s) => analyse(s).euler === s.chi);
// group the picker by topology
const groups = [
  { title: 'Spheres · χ = 2', match: 'S²' },
  { title: 'Tori · χ = 0', match: 'T²' },
  { title: 'Genus 2 · χ = −2', match: 'Σ₂' },
].map((g) => ({
  title: g.title,
  items: surfaces.map((s, i) => ({ s, i })).filter(({ s }) => s.name === g.match),
}));
---

<section class="hero" aria-label="Intro">
  <div class="hero-fig">
    <canvas id="net" aria-hidden="true" title="Click for a random surface"></canvas>
  </div>

  <div class="hero-body wrap">
    <div class="hero-text">
      <p class="kicker">machine-checked mathematics <b>×</b> real-world signals</p>
      <!-- keep on one line: Astro collapses whitespace before inline elements at line breaks -->
      <h1 class="title">I turn <span class="g2">theorems</span> into machine-checked proofs, and <span class="g1">brain signals</span> into data.</h1>
      <p class="lead">
        Mathematics in Lean 4 — manifolds and Morse theory — plus fNIRS &amp; EEG signal
        processing in Python by day. This site is my notebook: notes published while I learn.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/lean-proof">See a proof →</a>
        <a class="btn ghost" href="/about">More about me</a>
      </div>
    </div>

    <div class="hero-controls" id="heroControls">
      <div class="hc-pick">
        <details class="hc-picker" id="hcPicker">
          <summary class="hc-chip hc-summary" id="hcCurrent">Surface</summary>
          <div class="hc-menu" role="group" aria-label="Choose a surface">
            {groups.map((g) =>
              g.items.length > 0 && (
                <Fragment>
                  <span class="hc-group">{g.title}</span>
                  {g.items.map(({ s, i }) => (
                    <button class="hc-chip" data-i={i} type="button" aria-pressed="false" title={`${s.name} — ${s.desc}`}>
                      <b>{s.name}</b> {s.label}
                    </button>
                  ))}
                </Fragment>
              ),
            )}
          </div>
        </details>
        <button id="hcRandom" class="hc-chip hc-random" type="button">🎲 Random</button>
      </div>
      <div class="hc-sweep">
        <label for="hcSlider">sweep the height</label>
        <input id="hcSlider" type="range" min="0" max="1000" value="0" aria-label="Sweep the height function a" />
      </div>
      <p class="hc-readout" id="hcReadout">
        <span id="hcName" class="hc-name"></span>
        <span id="hcChi" class="hc-chi"></span>
        <span id="hcLevel" class="hc-level"></span>
        <span id="hcPassed" class="hc-passed"></span>
        <span id="hcCounts" class="hc-counts"></span>
        <span id="hcSum" class="hc-sum"></span>
      </p>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: calc(100svh - 64px); display: flex; align-items: stretch; overflow: hidden }
  /* fills the hero vertically; text centered inside, controls anchored bottom */
  .hero-body {
    position: relative; z-index: 2; flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding-top: 40px; padding-bottom: 40px; pointer-events: none;
  }
  .hero-text > *, .hero-controls { pointer-events: auto }
  .kicker { font-family: var(--mono); font-size: 13px; letter-spacing: .06em; color: var(--muted); margin: 0 0 18px }
  .kicker b { color: var(--violet) }
  /* a step smaller than the sketch's 88px — gives the surface room to breathe */
  h1.title { font-size: clamp(40px, 7vw, 74px); font-weight: 700; max-width: 15ch }
  h1.title .g1 { background: linear-gradient(92deg, var(--hbo), var(--amber)); -webkit-background-clip: text; background-clip: text; color: transparent }
  h1.title .g2 { background: linear-gradient(92deg, var(--blue), var(--violet)); -webkit-background-clip: text; background-clip: text; color: transparent }
  .lead { font-size: clamp(17px, 2vw, 20px); color: var(--muted); max-width: 46ch; margin: 22px 0 30px }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px }

  /* the figure is a full-bleed background; the surface renders on the right
     (hero.ts) and a fade mask keeps the wireframe out of the text column */
  .hero-fig { position: absolute; inset: 0; z-index: 1 }
  #net { position: absolute; inset: 0; width: 100%; height: 100%; display: block; cursor: pointer }
  html:not(.js) .hero-fig { display: none } /* the canvas is a JS enhancement */
  @media (min-width: 821px) {
    #net {
      -webkit-mask-image: linear-gradient(90deg, transparent 0%, transparent 38%, rgba(0, 0, 0, .5) 52%, #000 66%);
      mask-image: linear-gradient(90deg, transparent 0%, transparent 38%, rgba(0, 0, 0, .5) 52%, #000 66%);
    }
  }

  /* seamless controls — no card chrome, just quiet type. On mid-width
     desktops they flow under the CTAs (the surface sits beside them); on
     wide screens they sit bottom-right, directly under the surface they
     drive (hero.ts reserves vertical room for them there). Either way the
     manifold stays in view while you play. */
  .hero-controls { display: flex; flex-direction: column; gap: 9px }
  @media (min-width: 821px) {
    .hero-controls { max-width: 430px; margin-top: 30px }
  }
  @media (min-width: 1121px) {
    .hero-controls { position: absolute; right: 24px; bottom: 26px; width: min(430px, 44%); margin-top: 0 }
  }
  html:not(.js) .hero-controls { display: none }

  .hc-pick { display: flex; gap: 8px; align-items: center; flex-wrap: wrap }
  .hc-chip {
    display: inline-flex; align-items: center;
    font-family: var(--mono); font-size: 11.5px; color: var(--muted); cursor: pointer;
    background: none; border: 1px solid var(--border);
    border-radius: 999px; padding: 5px 10px; transition: color .15s, border-color .15s, background .15s;
  }
  .hc-chip b { color: var(--ink); font-weight: 700; margin-right: 3px }
  .hc-chip:hover { border-color: var(--violet) }
  .hc-chip[aria-pressed="true"] { border-color: var(--violet); background: color-mix(in srgb, var(--violet) 14%, transparent); color: var(--ink) }

  /* the expandable surface menu (native <details>, opens upward) */
  .hc-picker { position: relative }
  .hc-summary { list-style: none; color: var(--ink); user-select: none }
  .hc-summary::-webkit-details-marker { display: none }
  .hc-summary::after { content: "▾"; margin-left: 7px; color: var(--muted); transition: transform .18s ease }
  .hc-picker[open] .hc-summary::after { transform: rotate(180deg) }
  .hc-picker[open] .hc-summary { border-color: var(--violet) }
  .hc-menu {
    position: absolute; bottom: calc(100% + 8px); left: 0; z-index: 6;
    width: min(320px, calc(100vw - 64px));
    display: grid; grid-template-columns: 1fr 1fr; gap: 6px; padding: 12px;
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    box-shadow: 0 18px 50px -20px color-mix(in srgb, var(--ink) 40%, transparent);
  }
  .hc-group {
    grid-column: 1 / -1; font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-top: 2px;
  }
  @media (prefers-reduced-motion: reduce) { .hc-summary::after { transition: none } }

  .hc-sweep { display: flex; flex-direction: column; gap: 2px }
  .hc-sweep label { font-size: 11.5px; color: var(--muted); font-family: var(--mono); display: flex; gap: 8px; align-items: baseline }
  .hc-level { color: var(--ink) }
  #hcSlider { width: 100%; accent-color: var(--violet); height: 26px; cursor: pointer; margin: 0 }
  /* on mouse desktops the cursor itself sweeps the level — the slider is
     redundant there (it stays wherever touch is the pointer) */
  @media (min-width: 821px) and (hover: hover) and (pointer: fine) {
    .hc-sweep { display: none }
  }

  .hc-readout { margin: 0; font-family: var(--mono); font-size: 11.5px; color: var(--muted); display: flex; flex-wrap: wrap; gap: 3px 14px }
  .hc-name { color: var(--ink) }
  .hc-chi { color: var(--violet); font-weight: 700; white-space: nowrap }
  .hc-sum.done { color: var(--mint); font-weight: 700 }

  /* mobile: contained, in-flow figure below the controls — no overlap with
     the text is even possible, and everything is driven by the slider/chips */
  @media (max-width: 820px) {
    .hero { flex-direction: column; min-height: 0; padding-bottom: 32px }
    /* the figure is first in the DOM (desktop paint order) but on phones it
       belongs BELOW the controls that drive it */
    .hero-body { order: 1 }
    .hero-fig { order: 2 }
    .hero-body { padding-top: 24px; padding-bottom: 0; justify-content: flex-start }
    h1.title { font-size: clamp(34px, 9.6vw, 44px) }
    .lead { font-size: 17px }
    .hero-controls { margin-top: 22px }
    .hc-chip { min-height: 44px; padding: 6px 12px; font-size: 12px } /* phone tap-target floor */
    #hcSlider { height: 44px }
    .hero-fig { position: static; margin: 14px 24px 0 }
    #net { position: relative; width: 100%; height: 260px }
  }
</style>

<script>
  import { initHero } from '../scripts/hero';
  initHero();
</script>
