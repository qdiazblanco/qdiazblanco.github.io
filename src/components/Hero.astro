---
import { SURFACES, analyse } from '../lib/morse';
// Same filter the canvas uses, so chip indices line up with hero.ts.
const surfaces = SURFACES.filter((s) => analyse(s).euler === s.chi);
---

<section class="hero" aria-label="Intro">
  <div class="hero-body wrap">
    <div class="hero-text">
      <p class="kicker">machine-checked mathematics <b>×</b> real-world signals</p>
      <!-- keep on one line: Astro collapses whitespace before inline elements at line breaks -->
      <h1 class="title">I turn <span class="g2">theorems</span> into machine-checked proofs, and <span class="g1">brain signals</span> into data.</h1>
      <p class="lead">
        Mathematics in Lean 4 — manifolds and Morse theory — plus fNIRS &amp; EEG signal
        processing in Python by day. This site is my notebook: notes published while I learn.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/lean-proof">See a proof →</a>
        <a class="btn ghost" href="/about">More about me</a>
      </div>
    </div>

    <div class="hero-controls" id="heroControls">
      <p class="hc-hint">A different surface every visit — sweep the height function, change the manifold, and watch Σ(−1)ⁱ add up to χ.</p>
      <div class="hc-surfaces" id="hcSurfaces" role="group" aria-label="Choose a surface">
        {surfaces.map((s, i) => (
          <button class="hc-chip" data-i={i} type="button" aria-pressed="false" title={`${s.name} — ${s.desc}`}>
            <b>{s.name}</b> {s.label}
          </button>
        ))}
      </div>
      <div class="hc-sweep">
        <label for="hcSlider">Sweep the height <span id="hcLevel" class="hc-level"></span></label>
        <input id="hcSlider" type="range" min="0" max="1000" value="0" aria-label="Sweep the height function a" />
      </div>
      <div class="hc-readout" id="hcReadout" aria-live="polite">
        <div class="hc-r-top">
          <span id="hcName" class="hc-name"></span>
          <span id="hcChi" class="hc-chi"></span>
        </div>
        <div class="hc-r-live">
          <span id="hcPassed" class="hc-passed"></span>
          <span id="hcCounts" class="hc-counts"></span>
          <span id="hcSum" class="hc-sum"></span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-fig">
    <canvas id="net" aria-hidden="true"></canvas>
  </div>
</section>

<style>
  .hero { position: relative; min-height: calc(100svh - 64px); display: flex; align-items: center; overflow: hidden }
  .hero-body { position: relative; z-index: 2; width: 100%; padding: 40px 24px 80px; pointer-events: none }
  .hero-text > *, .hero-controls { pointer-events: auto }
  .kicker { font-family: var(--mono); font-size: 13px; letter-spacing: .06em; color: var(--muted); margin: 0 0 18px }
  .kicker b { color: var(--violet) }
  h1.title { font-size: clamp(44px, 8.5vw, 88px); font-weight: 700; max-width: 15ch }
  h1.title .g1 { background: linear-gradient(92deg, var(--hbo), var(--amber)); -webkit-background-clip: text; background-clip: text; color: transparent }
  h1.title .g2 { background: linear-gradient(92deg, var(--blue), var(--violet)); -webkit-background-clip: text; background-clip: text; color: transparent }
  .lead { font-size: clamp(18px, 2.2vw, 22px); color: var(--muted); max-width: 46ch; margin: 22px 0 30px }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px }

  /* desktop: the figure is a full-bleed background; the surface renders on
     the right (see hero.ts cx≈0.73w), the controls live in the left column */
  .hero-fig { position: absolute; inset: 0; z-index: 1 }
  #net { position: absolute; inset: 0; width: 100%; height: 100%; display: block }
  html:not(.js) .hero-fig { display: none } /* the canvas is a JS enhancement */

  .hero-controls {
    max-width: 380px; margin-top: 30px;
    background: color-mix(in srgb, var(--surface) 86%, transparent); backdrop-filter: blur(8px) saturate(1.3);
    border: 1px solid var(--border); border-radius: 14px; padding: 14px 16px;
    display: flex; flex-direction: column; gap: 10px;
  }
  /* chips are server-rendered, so the panel is shown at once (no fade); the
     whole thing is still gated on JS since it drives the canvas */
  html:not(.js) .hero-controls { display: none }

  .hc-hint { margin: 0; font-size: 12.5px; color: var(--muted); line-height: 1.45 }
  .hc-surfaces { display: flex; flex-wrap: wrap; gap: 6px }
  .hc-chip {
    font-family: var(--mono); font-size: 12px; color: var(--muted); cursor: pointer;
    background: color-mix(in srgb, var(--ink) 5%, transparent); border: 1px solid var(--border);
    border-radius: 999px; padding: 6px 11px; transition: color .15s, border-color .15s, background .15s;
  }
  .hc-chip b { color: var(--ink); font-weight: 700; margin-right: 3px }
  .hc-chip:hover { border-color: var(--violet) }
  .hc-chip[aria-pressed="true"] { border-color: var(--violet); background: color-mix(in srgb, var(--violet) 16%, transparent); color: var(--ink) }

  .hc-sweep { display: flex; flex-direction: column; gap: 4px }
  .hc-sweep label { font-size: 12px; color: var(--muted); font-family: var(--mono); display: flex; gap: 8px; align-items: baseline }
  .hc-level { color: var(--ink); font-weight: 500 }
  #hcSlider { width: 100%; accent-color: var(--violet); height: 24px; cursor: pointer }

  .hc-readout { font-family: var(--mono); font-size: 12px; display: flex; flex-direction: column; gap: 4px }
  .hc-r-top { display: flex; justify-content: space-between; gap: 10px; align-items: baseline }
  .hc-name { color: var(--ink); font-weight: 500 }
  .hc-chi { color: var(--violet); font-weight: 700; white-space: nowrap }
  .hc-r-live { display: flex; flex-wrap: wrap; gap: 4px 12px; color: var(--muted) }
  .hc-sum.done { color: var(--mint); font-weight: 700 }

  /* mobile: figure becomes a contained, in-flow interactive card below the
     controls — no overlap with the text is even possible */
  @media (max-width: 820px) {
    .hero { flex-direction: column; align-items: stretch; min-height: 0; padding-bottom: 32px }
    .hero-body { padding: 24px 24px 0 }
    h1.title { font-size: clamp(34px, 9.6vw, 44px) }
    .lead { font-size: 17px }
    .hero-controls { max-width: none }
    .hero-fig { position: static; margin: 18px 24px 0 }
    #net { position: relative; width: 100%; height: 260px }
  }
</style>

<script>
  import { initHero } from '../scripts/hero';
  initHero();
</script>
