---
import { getPosts } from '../lib/posts';

interface Props {
  path?: string;
}
const { path = '/' } = Astro.props;

// the Notebook link appears only once there is something to read (drafts
// count in dev so writing can be previewed) — no empty sections, ever
const hasNotebook = (await getPosts()).length > 0;

// Contact is reached via the envelope icon (kept visible at every width),
// not a fifth text link — per Quique. Internal links carry trailing slashes:
// GitHub Pages 301-redirects the slash-less forms on every click otherwise.
const links = [
  { href: '/', label: 'Home' },
  ...(hasNotebook ? [{ href: '/notebook/', label: 'Notebook' }] : []),
  { href: '/about/', label: 'About' },
  { href: '/lean-proof/', label: 'See a proof' },
];
// active when the path matches, or (for non-home) when it's a sub-path
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href);

---

<header class="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="/"><svg class="glyph" viewBox="6 6 88 88" aria-hidden="true"><path d="M46.00145348837209 43.0406976744186 38.24854651162791 17.34011627906977Q37.69912790697675 15.325581395348834 35.928779069767444 13.98255813953488Q34.158430232558146 12.639534883720927 30.61773255813954 11.968023255813954L31.350290697674424 8.0H44.41424418604652Q45.57412790697675 8.854651162790695 46.79505813953489 13.25L52.350290697674424 34.799418604651166Q56.74563953488372 28.32848837209302 64.37645348837209 15.264534883720927L68.64970930232559 8.0H87.26889534883722L86.84156976744185 10.38081395348837Q78.23401162790698 21.979651162790695 57.47819767441861 52.13662790697674L66.63517441860466 82.65988372093022Q67.48982558139535 85.52906976744185 68.95494186046511 86.62790697674419Q70.42005813953489 87.72674418604652 72.43459302325581 88.03197674418604L71.70203488372093 92.0H60.40843023255814Q59.12645348837209 90.96220930232558 57.600290697674424 84.79651162790697L51.00726744186046 60.01162790697674Q41.54505813953489 73.80813953488372 31.22819767441861 92.0H12.731104651162795L13.097383720930237 89.98546511627907Q16.88226744186047 84.85755813953489 28.664244186046517 67.88662790697674Z" fill="currentColor"/></svg>Enrique Díaz Blanco</a>

    <nav class="links" id="links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : undefined} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>

    <div class="nav-right">
      <button id="themeBtn" class="icon-btn" type="button" aria-label="Switch colour theme">
        <svg class="i-sun" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="i-moon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
      <a class="icon-btn" href="https://github.com/qdiazblanco" aria-label="GitHub" rel="me">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.3.8 1 .8 2.1v3.1c0 .3.2.7.8.6A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z" /></svg>
      </a>
      <a class={`icon-btn contact-btn${isActive('/contact/') ? ' active' : ''}`} href="/contact/" aria-label="Contact">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"><rect x="2.5" y="4.5" width="19" height="15" rx="2"/><path d="M3 6l9 6 9-6"/></svg>
      </a>
      <button class="menu-btn icon-btn" id="menuBtn" aria-label="Toggle menu" aria-expanded="false">☰</button>
    </div>
  </div>
</header>

<style>
  header.nav {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: saturate(1.4) blur(10px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner { display: flex; align-items: center; gap: 18px; height: 64px }
  .brand {
    font-family: var(--disp); font-weight: 700; font-size: 18px; letter-spacing: -.02em; text-decoration: none;
    display: inline-flex; align-items: center; gap: 10px; margin-right: auto; white-space: nowrap;
  }
  /* the brand mark is the same χ path as the favicon — ink-colored, so it
     flips with the theme like the name beside it */
  .brand .glyph { width: 30px; height: 30px; flex-shrink: 0 }
  nav.links { display: flex; gap: 26px }
  nav.links a {
    font-size: 14.5px; font-weight: 500; text-decoration: none; color: var(--muted);
    padding: 6px 2px; position: relative; transition: color .18s;
  }
  nav.links a:hover, nav.links a.active { color: var(--ink) }
  nav.links a::after {
    content: ""; position: absolute; left: 0; right: 100%; bottom: 0; height: 2px; border-radius: 2px;
    background: var(--violet); transition: right .22s ease;
  }
  nav.links a:hover::after, nav.links a.active::after { right: 0 }

  .nav-right { display: flex; align-items: center; gap: 4px }
  .icon-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 12px; border: 0; background: none;
    color: var(--muted); cursor: pointer; text-decoration: none; transition: color .18s, background .18s;
  }
  .icon-btn:hover, .icon-btn.active { color: var(--ink); background: color-mix(in srgb, var(--ink) 8%, transparent) }
  .icon-btn svg { width: 20px; height: 20px }
  /* the theme button shows the icon for the theme you'd switch TO */
  .i-sun { display: none }
  :root[data-theme="dark"] .i-moon { display: none }
  :root[data-theme="dark"] .i-sun { display: block }
  .menu-btn { display: none; font-size: 18px; color: var(--ink) }

  /* 820px (not 720) — with five text links the bar needs ~800px, and this
     matches the site's other breakpoint */
  @media (max-width: 820px) {
    nav.links {
      position: fixed; inset: 64px 0 auto 0; flex-direction: column; gap: 0; background: var(--surface);
      border-bottom: 1px solid var(--border); padding: 8px 24px 16px; transform: translateY(-140%);
      /* visibility:hidden takes the links out of the tab order while closed
         (transform alone leaves them as off-screen phantom tab stops); the
         delayed visibility transition lets them slide out before hiding */
      visibility: hidden; transition: transform .28s ease, visibility 0s linear .28s;
    }
    nav.links.open { transform: translateY(0); visibility: visible; transition: transform .28s ease, visibility 0s }
    nav.links a { padding: 14px 0; border-bottom: 1px solid var(--border) }
    .menu-btn { display: inline-flex }
    /* free up the crowded bar — but the envelope stays: it is THE route to
       the contact page at every width */
    .nav-right a.icon-btn:not(.contact-btn) { display: none }
    .brand { font-size: 16px }
  }
  @media (prefers-reduced-motion: reduce) { nav.links { transition: none } }
</style>

<script>
  // theme toggle — persists the choice and tells the hero canvas to re-read
  const themeBtn = document.getElementById('themeBtn');
  themeBtn?.addEventListener('click', () => {
    const el = document.documentElement;
    const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch (e) {
      /* private mode — the in-memory switch still works */
    }
    window.dispatchEvent(new CustomEvent('themechange'));
  });

  // mobile menu
  const btn = document.getElementById('menuBtn');
  const links = document.getElementById('links');
  if (btn && links) {
    btn.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    links.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        links.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }),
    );
  }
</script>
