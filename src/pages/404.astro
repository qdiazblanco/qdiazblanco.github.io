---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Enrique Díaz Blanco" description="This level set is empty." noindex>
  <section class="block nf">
    <div class="wrap">
      <p class="eyebrow"><span class="dot"></span>404</p>
      <h1 class="nf-h1">This level set is empty.</h1>
      <p class="lede">
        The sweep passed <code>a = 404</code> and found no critical points — whatever was
        supposed to be here doesn't change the topology. Nothing was attached.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/">Back to the surface →</a>
        <a class="btn ghost" href="/notebook/">Read the notebook</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { min-height: calc(70svh - 64px); display: flex; align-items: center }
  .nf-h1 { font-size: clamp(34px, 6vw, 64px) }
  .lede code {
    font-family: var(--mono); font-size: .85em;
    background: color-mix(in srgb, var(--violet) 12%, var(--surface));
    color: var(--violet-ink); /* raw violet is 4.0:1 on this tint in dark — AA needs 4.5 */
    padding: 2px 8px; border-radius: 6px;
  }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px }
</style>
