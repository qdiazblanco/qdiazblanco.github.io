---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Contact from '../components/Contact.astro';
---

<Base>
  <Hero />

  <section class="block">
    <div class="wrap">
      <p class="eyebrow reveal"><span class="dot"></span>Explore</p>
      <h2 class="reveal">Where to next?</h2>
      <div class="cards">
        <a class="card reveal" href="/lean-proof/">
          <span class="tag t-violet">Lean</span>
          <h3>See through a Lean proof</h3>
          <p>Watch a theorem check itself, one tactic at a time — no Lean install required.</p>
          <span class="go">Step through it →</span>
        </a>
        <a class="card reveal" href="/about/">
          <span class="tag t-blue">About</span>
          <h3>What I actually do</h3>
          <p>Manifolds and Morse theory by night; brain signals by day. The longer story.</p>
          <span class="go">Read more →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <p class="eyebrow reveal"><span class="dot"></span>Who's behind this</p>
      <h2 class="reveal">In one breath</h2>
      <!-- keep links on one line: Astro collapses whitespace before inline elements at line breaks -->
      <p class="lede reveal">I'm Enrique — everyone calls me Quique. I do formal mathematics in Lean 4 (manifolds, Morse theory), I co-organize <a href="https://madlean-hub.web.app">MadLean</a>, Madrid's Lean community, and by day I wrangle fNIRS &amp; EEG signals in Python. This site is my notebook — imperfect notes published while I learn.</p>
      <p class="reveal about-more"><a class="btn ghost" href="/about/">More about me →</a></p>
    </div>
  </section>

  <Contact />
</Base>

<style>
  .about-more { margin-top: 26px }
</style>
