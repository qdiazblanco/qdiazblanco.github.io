---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { fmtDate, getPosts } from '../../lib/posts';
import '../../styles/prose.css';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const growthGlyph = { seedling: '🌱', growing: '🌿', evergreen: '🌲' } as const;
---

<Base title={`${d.title} — Enrique Díaz Blanco`} description={d.description} ogType="article">
  <article class="block post-page">
    <div class="wrap">
      <header class="post-head reveal">
        <p class="meta-line">
          <span class={`kindtag k-${d.kind}`}>{d.kind}</span>
          {d.growth && <span class="growth" title={`growth: ${d.growth}`}>{growthGlyph[d.growth]} {d.growth}</span>}
          {d.draft && <span class="draft-badge">draft — not in the published site</span>}
        </p>
        <h1>{d.title}</h1>
        <p class="post-desc">{d.description}</p>
        <p class="meta-line dates">
          <time datetime={d.date.toISOString()}>{fmtDate(d.date)}</time>
          {d.updated && <span>· updated <time datetime={d.updated.toISOString()}>{fmtDate(d.updated)}</time></span>}
          {d.tags.length > 0 && <span class="tags">· {d.tags.map((t) => <span class="tag-ref">#{t}</span>)}</span>}
        </p>
      </header>
      <div class="prose reveal">
        <Content />
      </div>
      <p class="back reveal"><a href="/notebook/">← all notes &amp; essays</a></p>
    </div>
  </article>
</Base>

<style>
  .post-head { max-width: 68ch }
  .post-head h1 { font-size: clamp(30px, 4.6vw, 44px); margin: 14px 0 10px }
  .post-desc { color: var(--muted); font-size: 18px; margin: 0 0 14px }
  .meta-line { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin: 0 }
  .meta-line.dates { font-family: var(--mono); font-size: 13px; color: var(--muted); margin-top: 6px }
  .kindtag {
    font-family: var(--mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 999px; font-weight: 500;
  }
  .k-note { background: color-mix(in srgb, var(--mint) 16%, var(--surface)); color: var(--mint-ink) }
  .k-essay { background: color-mix(in srgb, var(--violet) 14%, var(--surface)); color: var(--violet-ink) }
  .growth { font-family: var(--mono); font-size: 12px; color: var(--muted) }
  .draft-badge {
    font-family: var(--mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: .05em;
    color: var(--amber-ink); border: 1px dashed var(--amber-ink); border-radius: 999px; padding: 2px 8px;
  }
  .tag-ref { margin-right: 6px }
  .prose { margin-top: 34px }
  .back { margin-top: 48px; font-family: var(--mono); font-size: 14px }
  .back a { color: var(--muted); text-decoration: none }
  .back a:hover { color: var(--violet) }
</style>
