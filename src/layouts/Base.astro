---
// Fonts are self-hosted via @fontsource (no Google Fonts request):
// faster first paint, no third-party dependency, offline dev.
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/tokens.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** posts pass 'article' for nicer link previews */
  ogType?: 'website' | 'article';
  /** error pages opt out of indexing (their canonical URL never returns 200) */
  noindex?: boolean;
}
const {
  title = 'Enrique Díaz Blanco — proofs & signals',
  description = 'Formal mathematics in Lean 4 — manifolds and Morse theory — plus fNIRS/EEG signal processing. A digital notebook, learning in public.',
  ogType = 'website',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="alternate" type="application/rss+xml" title="Enrique Díaz Blanco — proofs & signals" href="/rss.xml" />
    <!-- link previews (Slack/Zulip/WhatsApp/X…) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Enrique Díaz Blanco — proofs & signals" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // is:inline + in <head> = runs during parsing, before first paint:
      // no theme flash, and CSS hides .reveal only when JS can reveal it.
      (function () {
        var el = document.documentElement;
        try {
          var stored = localStorage.getItem('theme'); // 'light' | 'dark' | null
          var dark = stored
            ? stored === 'dark'
            : matchMedia('(prefers-color-scheme: dark)').matches;
          el.dataset.theme = dark ? 'dark' : 'light';
        } catch (e) {
          el.dataset.theme = 'light';
        }
        el.classList.add('js');
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav path={Astro.url.pathname} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // scroll reveal for .reveal elements
      const els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window)) {
        els.forEach((e) => e.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (ents) => {
            for (const en of ents)
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
          },
          // threshold 0 (any visible pixel): a fractional threshold can NEVER
          // fire for elements taller than ~1/threshold viewports — a whole
          // long post wrapped in .reveal would stay invisible forever
          { threshold: 0 },
        );
        els.forEach((e) => io.observe(e));
      }
    </script>
  </body>
</html>
