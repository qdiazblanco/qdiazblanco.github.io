---
// Fonts are self-hosted via @fontsource (no Google Fonts request):
// faster first paint, no third-party dependency, offline dev.
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/tokens.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Enrique Díaz Blanco — proofs & signals',
  description = 'Formal mathematics in Lean 4 — manifolds and Morse theory — plus fNIRS/EEG signal processing. A digital notebook, learning in public.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // is:inline is required: a bare script becomes a deferred module and
      // would stamp too late — this must run during parsing, before first
      // paint, so CSS hides .reveal only when JS will reveal it again
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <Nav />
    <main id="top">
      <slot />
    </main>
    <Footer />
    <script>
      // scroll reveal for .reveal elements
      const els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window)) {
        els.forEach((e) => e.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (ents) => {
            for (const en of ents)
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
          },
          { threshold: 0.12 },
        );
        els.forEach((e) => io.observe(e));
      }
    </script>
  </body>
</html>
